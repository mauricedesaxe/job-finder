{
  "name": "jobfinder",
  "version": "2026.04.01.1",
  "description": "Automated job search and enrichment pipeline. Searches job boards, evaluates listings with Claude, and stores qualified jobs in Notion.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mauricedesaxe/job-finder.git"
  },
  "keywords": [
    "job-search",
    "scraping",
    "notion",
    "llm",
    "automation",
    "claude"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "scrape": "bun src/index.ts",
    "reconcile": "bun src/index.ts --reconcile-only",
    "test": "bun test src/**/__tests__/",
    "test:integration": "bun test src/**/__integration__/",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@evilmartians/lefthook": "2.1.4",
    "@types/bun": "1.3.11",
    "pino-pretty": "^13.1.3",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.80.0",
    "@notionhq/client": "2.3.0",
    "pino": "^10.3.1",
    "zod": "4.3.6"
  }
}
